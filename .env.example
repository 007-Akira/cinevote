# Public Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase credential; never expose this value to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Server-only admin login and session-signing secrets
ADMIN_PASSWORD=
ADMIN_COOKIE_SECRET=

# Server-only signing secret for trusted voter-device cookies
DEVICE_COOKIE_SECRET=

# Public deployed application URL, for example https://cinevote.example.com
NEXT_PUBLIC_SITE_URL=
